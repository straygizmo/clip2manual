{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "out/tsc"
  },
  "include": [
    "src/main",
    "src/preload",
    "src/shared",
